    {
      "parameters": {
        "jsCode": "const newVector = $input.first().json.embedding.values;\nconst pastEmbeddings = $('Code in JavaScript1').first().json.pastEmbeddings; \n\nfunction cosineSimilarity(a, b) {\n  let dot = 0, magA = 0, magB = 0;\n  for (let i = 0; i < a.length; i++) {\n    dot += a[i] * b[i];\n    magA += a[i] * a[i];\n    magB += b[i] * b[i];\n  }\n  return dot / (Math.sqrt(magA) * Math.sqrt(magB));\n}\n\nlet maxSimilarity = 0;\nfor (const entry of pastEmbeddings) {\n  const sim = cosineSimilarity(newVector, entry.vector);\n  if (sim > maxSimilarity) maxSimilarity = sim;\n}\n\nconst isDuplicate = maxSimilarity > 0.85; \n\nreturn [{\n  json: {\n    idea: $('Message a model2').first().json.content.parts[0].text, \n    embedding: JSON.stringify(newVector),\n    isDuplicate,\n    maxSimilarity\n  }\n}];"
      },
