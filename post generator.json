      "parameters": {
        "jsCode": "const rows = $input.all().map(item => item.json);\nconst pastEmbeddings = rows\n  .filter(r => r.Embedding)\n  .map(r => ({\n    idea: r.idea,\n    vector: JSON.parse(r.Embedding)\n  }));\n\nconst recentIdeas = rows.slice(-30).map(r => r.idea).join(\", \");\n\nreturn [{\n  json: {\n    pastEmbeddings,\n    recentIdeas\n  }\n}];"
      },
